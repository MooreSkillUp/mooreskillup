# Environment Configuration Example
# Copy this file to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Contact Form (Formspree)
# Get your form ID from https://formspree.io
# Format: f/YOUR_CONTACT_FORM_ID
NEXT_PUBLIC_FORMSPREE_FORM_ID=f/YOUR_FORMSPREE_FORM_ID

# WhatsApp Configuration
# Your WhatsApp business number (including country code, no spaces/dashes)
# Example: 1234567890 for +1 234 567 890
NEXT_PUBLIC_WHATSAPP_NUMBER=1234567890

# App Configuration
NEXT_PUBLIC_APP_NAME=MooreSkillUp
NEXT_PUBLIC_APP_URL=http://localhost:3000

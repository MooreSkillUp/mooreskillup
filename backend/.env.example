# ============================================================
# MooreSkillUp — Backend environment (copy to backend/.env)
# .env is git-ignored. Never commit real secret keys.
# ============================================================

# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (Docker Postgres) ---
# Use DATABASE_HOST=db when running via docker-compose (the service name).
# Use DATABASE_HOST=localhost when running Postgres directly on your machine.
DATABASE_NAME=mooreskillup
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=db
DATABASE_PORT=5432

# --- Frontend links ---
# CORS_ALLOWED_ORIGINS: where the browser app runs (the frontend origin).
# FRONTEND_URL: used to build links inside emails (e.g. password-reset, verify).
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# --- Email ---
# Dev default: console backend prints emails to `docker compose logs -f api`
# (nothing is actually sent). For a real inbox, switch EMAIL_BACKEND to SMTP and
# fill the host/user/password below (Gmail app password, Mailtrap, Resend SMTP, etc.).
EMAIL_SITE_NAME=MooreSkillUp
DEFAULT_FROM_EMAIL=noreply@mooreskillup.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# --- JWT auth ---
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# --- Admin bootstrap ---
# The one-time token to create the first Super Admin at /auth/admin-register.
# The page auto-disables once a Super Admin exists. Use a long random value.
ADMIN_REGISTRATION_TOKEN=change-this-admin-bootstrap-token

# --- Payments: Paystack (the only gateway) ---
# Leave PAYSTACK_SECRET_KEY empty (or as a placeholder) to run in SIMULATION
# mode: checkout completes locally without contacting Paystack. Set a real key
# (sk_test_... for testing, sk_live_... for production) to use the real API.
# The SAME secret key verifies webhook signatures — no separate webhook secret.
# Register your webhook URL in the Paystack dashboard:
#   https://YOUR-BACKEND/api/payments/webhooks/paystack/
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# --- Redis (reserved; not yet used by Django) ---
# In Docker use redis://redis:6379/0; locally redis://localhost:6379/0.
REDIS_URL=redis://redis:6379/0

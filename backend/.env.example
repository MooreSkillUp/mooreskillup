DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_NAME=mooreskillup
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
EMAIL_SITE_NAME=MooreSkillUp
# Email: with Docker, default console backend prints messages to `docker compose logs -f api` (no inbox).
# For a real inbox locally, use SMTP e.g. Gmail (app password) or https://mailtrap.io — then set:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# and fill EMAIL_HOST / EMAIL_PORT / EMAIL_HOST_USER / EMAIL_HOST_PASSWORD below.
DEFAULT_FROM_EMAIL=noreply@mooreskillup.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
ADMIN_REGISTRATION_TOKEN=change-this-admin-bootstrap-token
PAYSTACK_SECRET_KEY=paystack_test_secret
PAYSTACK_PUBLIC_KEY=paystack_test_public
PAYSTACK_WEBHOOK_SECRET=paystack_webhook_secret
OPAY_SECRET_KEY=opay_test_secret
OPAY_PUBLIC_KEY=opay_test_public
OPAY_WEBHOOK_SECRET=opay_webhook_secret
REDIS_URL=redis://redis:6379/0
